</main>
<script>
function show(id,btn){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('on'));
  document.querySelectorAll('.tb2').forEach(b=>b.classList.remove('on'));
  document.getElementById(id).classList.add('on');
  btn.classList.add('on');
  window.scrollTo({top:0,behavior:'smooth'});
}
function ans(btn,ok){
  const qc=btn.closest('.qc');
  qc.querySelectorAll('.ob').forEach(b=>{
    b.disabled=true;
    if(b.onclick.toString().includes(',true'))b.classList.add('ok');
  });
  if(!ok)btn.classList.add('no');
  qc.querySelector('.ex').classList.add('sh');
}
</script>
