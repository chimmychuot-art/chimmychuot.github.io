.de-row{display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;margin-bottom:6px;font-size:13px}
.de-header{font-weight:600;color:var(--ac);font-size:12px;text-transform:uppercase;border-bottom:1px solid var(--bd);padding-bottom:6px;margin-bottom:8px}
